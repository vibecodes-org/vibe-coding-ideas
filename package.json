{
  "name": "vibecodes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "supabase:start": "npx supabase start",
    "supabase:stop": "npx supabase stop",
    "supabase:reset": "npx supabase db reset",
    "supabase:migrate": "npx supabase migration up --local",
    "supabase:studio": "open http://localhost:54323",
    "screenshots": "npx playwright test --config e2e/screenshots/playwright.screenshots.config.ts",
    "demo:record": "npx playwright test --config e2e/videos/playwright.video.config.ts",
    "demo:assemble": "npx tsx e2e/videos/assemble-video.ts",
    "demo": "npm run demo:record && npm run demo:assemble"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.44",
