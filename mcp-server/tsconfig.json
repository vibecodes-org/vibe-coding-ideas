{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "noEmit": true,
    "baseUrl": ".",
    // Mirrors the root tsconfig's "@/*" -> "./src/*" alias (relative to repo root).
    // App-side lib files pulled in transitively by mcp-server tools (e.g.
    // workflow-helpers.ts, ai-role-matching.ts) import via "@/...". Without this
    // mapping tsc can't resolve those imports when run standalone from mcp-server/.
    // Keep this even if it looks unused at a glance.
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": [
    "src/**/*",
    "../src/types/**/*",
    "../src/lib/role-matching.ts",
    "../src/lib/enhance-prompts.ts",
    "../src/lib/validation.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
