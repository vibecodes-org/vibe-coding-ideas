{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "noEmit": true
  },
  "include": [
    "src/**/*",
    "../src/types/**/*",
    "../src/lib/role-matching.ts",
    "../src/lib/enhance-prompts.ts",
    "../src/lib/validation.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
